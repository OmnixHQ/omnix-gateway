{
  "name": "@ucp-gateway/server",
  "version": "0.1.0",
  "private": true,
  "description": "UCP Gateway HTTP server — Fastify application",
  "license": "Elastic-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "test:live": "RUN_LIVE_TESTS=true vitest run src/__tests__/live-magento.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "@omnixhq/ucp-js-sdk": "^2.0.0",
    "@ucp-gateway/adapters": "*",
    "@ucp-gateway/core": "*",
    "awilix": "^13.0.3",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.0",
    "pino": "^9.2.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@omnixhq/adapter-magento": ">=1.0.0",
    "@omnixhq/adapter-shopware": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@omnixhq/adapter-magento": {
      "optional": true
    },
    "@omnixhq/adapter-shopware": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.19.0",
    "typescript": "*",
    "vitest": "^1.6.0"
  }
}
